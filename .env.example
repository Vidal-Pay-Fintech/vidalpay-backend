# Runtime
NODE_ENV=development
PORT=3000
ENABLE_SWAGGER=true
BUILD_TIMESTAMP=2026-06-02T00:00:00.000Z
COMMIT_SHA=
RENDER_GIT_COMMIT=
RENDER_SERVICE_ID=

# Application
PRODUCT_NAME=Vidal Pay
APP_NAME=Vidal Pay
APP_URL=https://staging.vidalpay.com
FRONTEND_URL=https://staging.vidalpay.com
ADMIN_DASHBOARD_URL=https://staging-admin.vidalpay.com
BACKEND_PUBLIC_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
PAYMENT_REDIRECT_URL=https://staging.vidalpay.com/validate-payment
FROM_EMAIL=support@vidalpay.com
SUPPORT_EMAIL=support@vidalpay.com
SUPPORT_PHONE=+10000000000
CODE_EXPIRATION_MINUTES=30
PERMITTED_CHARACTERS=0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=vidalpay
MYSQL_USERNAME=root
MYSQL_PASSWORD=password

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_TOKEN_AUDIENCE=vidalpay-api
JWT_TOKEN_ISSUER=vidalpay-backend
JWT_ACCESS_TOKEN_TTL=3600s
JWT_REFRESH_TOKEN_TTL=7d
ENCRYPT_KEY=replace-with-32-plus-character-secret

# Provider modes
PAYMENT_PROVIDER_MODE=mock
USD_PROVIDER_MODE=mock
FX_PROVIDER_MODE=mock
KYC_PROVIDER_MODE=mock
CRYPTO_PROVIDER_MODE=mock
INVESTMENT_PROVIDER_MODE=mock
TAX_PROVIDER_MODE=mock
NOTIFICATION_PROVIDER_MODE=mock
FRAUD_PROVIDER_MODE=mock

# Feature flags
ENABLE_DEMO_MODE=true
ENABLE_NGN_WALLET=true
ENABLE_USD_WALLET=true
ENABLE_INTERNAL_TRANSFER=true
ENABLE_NGN_BANK_TRANSFER=true
ENABLE_USD_BANK_TRANSFER=true
ENABLE_FX_CONVERSION_DEMO=true
ENABLE_VIRTUAL_CARD_DEMO=true
ENABLE_CRYPTO_DEMO=false
ENABLE_INVESTMENT_DEMO=false
ENABLE_TAX_DEMO=false
ENABLE_PROVIDER_PENDING_STATES=false
ALLOW_STAGING_KYC_OVERRIDE=false

# Flutterwave
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_SECRET_KEY=
FLW_WEBHOOK_SECRET_HASH=

# Future/live providers
LEAD_BANK_API_KEY=
SMILE_ID_API_KEY=
VERTO_API_KEY=
ZERO_HASH_API_KEY=
COWRYWISE_API_KEY=
APRIL_API_KEY=
COLUMN_API_KEY=
ONESIGNAL_APP_ID=
SARDINE_API_KEY=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@vidalpay.com
RESEND_FROM_NAME=Vidal Pay

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SMS_SENDER_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack error notifications
SLACK_API_TOKEN=
SLACK_API_CHANNEL=#api
SLACK_BOT_NAME=Vidal Pay API Error Tracker
SLACK_BOT_ICON=:warning:
SLACK_API_URL=https://slack.com/api/chat.postMessage
